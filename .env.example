# ── Local development ────────────────────────────────────────────────────────
# Path to the VTON output images folder (1 350 images generated by the pipeline)
VTON_DIR=/absolute/path/to/westside_vton

# ── Vercel / production (CDN mode) ───────────────────────────────────────────
# Upload garment images and VTON outputs to an object-storage bucket (R2, S3 …)
# then set these two vars in your Vercel project settings.
# Leave blank to use local filesystem instead.
GARMENTS_CDN_URL=https://raw.githubusercontent.com/manideep896/westside-store-assets/main/garments
VTON_CDN_URL=https://raw.githubusercontent.com/manideep896/westside-store-assets/main/vton
